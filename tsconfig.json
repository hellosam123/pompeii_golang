{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2015",
		"lib": ["ES2020", "DOM"],
		"outDir": "./static/js",
		"rootDir": "./static/ts",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["static/ts/**/*.ts"],
	"exclude": ["node_modules"]
}
